# Copy to .env.local and fill in. Never commit .env.local.

# Vercel Blob: Project → Storage → Blob → copy read/write token (upload script only)
BLOB_READ_WRITE_TOKEN=

# After `npm run blob:upload`, paste the printed URL here for production hero video.
# Add the same key in Vercel (Production) and redeploy — NEXT_PUBLIC_* is inlined at build time.
# If you skip this, enable Git LFS under Vercel Project → Settings → Git or /hero/stage_2026.mp4 stays a pointer.
NEXT_PUBLIC_HERO_VIDEO_URL=
